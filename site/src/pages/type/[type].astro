---
import Base from '../../layouts/Base.astro';
import VideoCard from '../../components/VideoCard.astro';
import { loadVersions, groupByMajor, VIDEO_TYPE_LABELS, type VideoType } from '../../lib/schema';

export function getStaticPaths() {
  // version（予告・特別番組）は単独ページの要望対象外
  return (['character', 'trailblaze', 'music'] as const).map((type) => ({ params: { type } }));
}

const type = Astro.params.type as VideoType;
const label = VIDEO_TYPE_LABELS[type];

const byDate = (a: { publishedAt: string }, b: { publishedAt: string }) =>
  a.publishedAt.localeCompare(b.publishedAt);

// メジャーバージョンのトグルのみで区切り、中は公開日順の一気見（種別ページはネタバレ配慮なし）
const groups = groupByMajor(loadVersions())
  .map((group) => ({
    ...group,
    all: group.versions
      .flatMap((version) => version.videos)
      .filter((v) => v.type === type)
      .sort(byDate),
  }))
  .filter((group) => group.all.length > 0);

const total = groups.reduce((sum, g) => sum + g.all.length, 0);
---
<Base title={`${label} | 崩壊：スターレイル 開拓クエスト 動画ガイド`}>
  <h1>{label}</h1>
  <p class="sub">全 {total} 件（公開日順）</p>

  <p class="static-note">メジャーバージョンごとに公開日順で並べています。</p>

  {
    groups.map((group) => (
      <details class="major-toggle" open>
        <summary>
          <span class="major-ver">Ver.{group.major}.x</span>
          {group.arc && <span class="major-name">（{group.arc}）</span>}
          <span class="count">{group.all.length} 件</span>
        </summary>
        <div class="major-body">
          <div class="video-list">
            {group.all.map((video) => (
              <VideoCard video={video} />
            ))}
          </div>
        </div>
      </details>
    ))
  }
</Base>

<style>
  h1 {
    margin-bottom: 0.1rem;
  }
  .sub {
    margin: 0 0 1rem;
    color: var(--text-dim);
    font-family: var(--mono);
    font-size: 0.8rem;
  }
  .static-note {
    background: var(--surface);
    border: 1px solid var(--line);
    border-left: 3px solid var(--accent);
    border-radius: var(--radius);
    padding: 0.7rem 1rem;
    color: var(--text-dim);
    font-size: 0.88rem;
  }
  .major-toggle {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    margin: 0.8rem 0;
  }
  .major-toggle summary {
    cursor: pointer;
    padding: 0.8rem 1rem;
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    flex-wrap: wrap;
    list-style: none;
    font-size: 1.05rem;
  }
  .major-toggle summary::-webkit-details-marker {
    display: none;
  }
  .major-toggle summary::after {
    content: '－';
    margin-left: auto;
    color: var(--text-dim);
    font-family: var(--mono);
  }
  .major-toggle:not([open]) summary::after {
    content: '＋';
  }
  .major-toggle[open] summary {
    border-bottom: 1px solid var(--line);
  }
  .major-toggle summary:hover .major-name {
    color: var(--accent);
  }
  .major-ver {
    color: var(--accent);
    font-family: var(--mono);
    font-weight: 700;
  }
  .major-name {
    font-weight: 700;
    transition: color 0.15s;
  }
  .count {
    color: var(--text-dim);
    font-family: var(--mono);
    font-size: 0.76rem;
  }
  .major-body {
    padding: 0.9rem 1rem 1rem;
  }
  .video-list {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
  }
</style>
