---
import MajorPage from '../../../components/pages/MajorPage.astro';
import { loadVersions, groupByMajor, type MajorGroup } from '../../../lib/schema';

export function getStaticPaths() {
  const groups = groupByMajor(loadVersions('en'), 'en');
  return groups.map((group, i) => ({
    params: { major: group.major },
    props: { group, prev: groups[i - 1] ?? null, next: groups[i + 1] ?? null },
  }));
}

interface Props {
  group: MajorGroup;
  prev: MajorGroup | null;
  next: MajorGroup | null;
}
const { group, prev, next } = Astro.props;
---
<MajorPage lang="en" group={group} prev={prev} next={next} />
