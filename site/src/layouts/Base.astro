---
import { STRINGS, langBase, type Lang } from '../lib/i18n';

interface Props {
  title: string;
  description?: string;
  lang?: Lang;
}
const { title, lang = 'ja', description = STRINGS[lang].description } = Astro.props;
const t = STRINGS[lang];
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const root = langBase(base, lang);

// 言語切替リンク: 現在のパスの対応ページへ（ja ⇔ en）
// 注意: サブパス配信時、トップ等では pathname が末尾スラッシュなし（= base と完全一致しない）になるため両形を処理する
const pathname = Astro.url.pathname;
const baseNoSlash = base.slice(0, -1);
let rel: string;
if (pathname.startsWith(base)) {
  rel = pathname.slice(base.length);
} else if (pathname === baseNoSlash) {
  rel = '';
} else if (baseNoSlash && pathname.startsWith(`${baseNoSlash}/`)) {
  rel = pathname.slice(baseNoSlash.length + 1);
} else {
  rel = pathname.replace(/^\//, '');
}
const altHref = lang === 'en' ? base + rel.replace(/^en\/?/, '') : `${base}en/${rel}`;
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <a href={root} class="site-logo">
        <span class="logo-mark" aria-hidden="true"></span>
        <span class="logo-text">
          <span class="logo-eyebrow">{t.logoEyebrow}</span>
          {t.logoText}
        </span>
      </a>
      <a class="lang-switch" href={altHref}>{t.langSwitch}</a>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <p>{t.footerUnofficial}</p>
      <p>
        {t.footerRights1}<a href={t.footerChannelUrl} target="_blank" rel="noopener noreferrer">{t.footerChannelName}</a>{t.footerRights2}
      </p>
    </footer>
    <!-- GoatCounter: Cookie を使わないプライバシー配慮のアクセス計測（localhost は自動的にカウント対象外） -->
    <script
      data-goatcounter="https://trailblazer-notes.goatcounter.com/count"
      async
      src="https://gc.zgo.at/count.js"></script>
  </body>
</html>

<style is:global>
  :root {
    --bg: #0b0e19;
    --surface: #141a2e;
    --surface-2: #1d2440;
    --line: #2c3554;
    --text: #e9ecf8;
    --text-dim: #98a1c0;
    --accent: #d9a95c;
    --accent-soft: rgba(217, 169, 92, 0.13);
    --danger: #ff8f8f;
    --radius: 12px;
    --mono: ui-monospace, 'SF Mono', 'Cascadia Mono', Menlo, Consolas, monospace;
  }
  * {
    box-sizing: border-box;
  }
  body {
    margin: 0;
    background: var(--bg);
    color: var(--text);
    font-family: 'Hiragino Sans', 'Noto Sans JP', system-ui, sans-serif;
    line-height: 1.7;
    font-variant-numeric: tabular-nums;
  }
  h1,
  h2,
  h3 {
    text-wrap: balance;
  }
  p {
    text-wrap: pretty;
  }
  a {
    color: var(--accent);
  }
  :focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
    border-radius: 4px;
  }
  main {
    max-width: 960px;
    margin: 0 auto;
    padding: 1.5rem 1rem 3rem;
  }
  .site-header {
    border-bottom: 1px solid var(--line);
    padding: 0.8rem 1rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.8rem;
    flex-wrap: wrap;
  }
  .lang-switch {
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 0.2rem 0.85rem;
    color: var(--text-dim);
    font-size: 0.82rem;
    text-decoration: none;
    transition: border-color 0.15s, color 0.15s;
  }
  .lang-switch:hover {
    border-color: var(--accent);
    color: var(--accent);
  }
  .site-logo {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    color: var(--text);
    text-decoration: none;
    font-weight: 700;
  }
  .logo-mark {
    flex: 0 0 auto;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 0 4px var(--accent-soft);
  }
  .logo-text {
    display: flex;
    flex-direction: column;
    line-height: 1.35;
  }
  .logo-eyebrow {
    font-family: var(--mono);
    font-size: 0.6rem;
    font-weight: 400;
    letter-spacing: 0.18em;
    color: var(--text-dim);
  }
  .site-footer {
    border-top: 1px solid var(--line);
    color: var(--text-dim);
    font-size: 0.8rem;
    text-align: center;
    padding: 1rem;
  }
  h1 {
    font-size: 1.5rem;
    line-height: 1.4;
  }
  .lead {
    color: var(--text-dim);
  }
  .card-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    padding: 0;
    list-style: none;
  }
  @media (prefers-reduced-motion: reduce) {
    *,
    *::before,
    *::after {
      transition-duration: 0.01ms !important;
      animation-duration: 0.01ms !important;
    }
  }
</style>
