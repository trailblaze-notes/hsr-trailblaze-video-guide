---
interface Props {
  title: string;
  description?: string;
}
const { title, description = '『崩壊：スターレイル』のバージョン（開拓クエスト進行度）ごとに、ネタバレなしで見られる公式動画をまとめた非公式ファンサイト' } = Astro.props;
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
---
<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <a href={base} class="site-logo">
        <span class="logo-mark" aria-hidden="true"></span>
        <span class="logo-text">
          <span class="logo-eyebrow">HONKAI: STAR RAIL — FAN GUIDE</span>
          崩壊：スターレイル 開拓クエスト 動画ガイド
        </span>
      </a>
      <nav class="global-nav" aria-label="種別ページ">
        <a href={`${base}type/character/`}>キャラPV</a>
        <a href={`${base}type/trailblaze/`}>紀行PV</a>
        <a href={`${base}type/music/`}>曲</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <p>
        本サイトは個人運営の<strong>非公式ファンサイト</strong>です。HoYoverse / COGNOSPHERE とは関係ありません。
      </p>
      <p>
        掲載動画はすべて
        <a href="https://www.youtube.com/@Houkaistarrail_jp" target="_blank" rel="noopener noreferrer">『崩壊：スターレイル』公式 YouTube チャンネル</a>
        のものであり、動画・楽曲等の権利は COGNOSPHERE PTE. LTD. に帰属します。
      </p>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    --bg: #0b0e19;
    --surface: #141a2e;
    --surface-2: #1d2440;
    --line: #2c3554;
    --text: #e9ecf8;
    --text-dim: #98a1c0;
    --accent: #d9a95c;
    --accent-soft: rgba(217, 169, 92, 0.13);
    --danger: #ff8f8f;
    --radius: 12px;
    --mono: ui-monospace, 'SF Mono', 'Cascadia Mono', Menlo, Consolas, monospace;
  }
  * {
    box-sizing: border-box;
  }
  body {
    margin: 0;
    background: var(--bg);
    color: var(--text);
    font-family: 'Hiragino Sans', 'Noto Sans JP', system-ui, sans-serif;
    line-height: 1.7;
    font-variant-numeric: tabular-nums;
  }
  h1,
  h2,
  h3 {
    text-wrap: balance;
  }
  p {
    text-wrap: pretty;
  }
  a {
    color: var(--accent);
  }
  :focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
    border-radius: 4px;
  }
  main {
    max-width: 960px;
    margin: 0 auto;
    padding: 1.5rem 1rem 3rem;
  }
  .site-header {
    border-bottom: 1px solid var(--line);
    padding: 0.8rem 1rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.8rem;
    flex-wrap: wrap;
  }
  .global-nav {
    display: flex;
    gap: 0.9rem;
    font-size: 0.85rem;
  }
  .global-nav a {
    text-decoration: none;
  }
  .global-nav a:hover {
    text-decoration: underline;
  }
  .site-logo {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    color: var(--text);
    text-decoration: none;
    font-weight: 700;
  }
  .logo-mark {
    flex: 0 0 auto;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 0 4px var(--accent-soft);
  }
  .logo-text {
    display: flex;
    flex-direction: column;
    line-height: 1.35;
  }
  .logo-eyebrow {
    font-family: var(--mono);
    font-size: 0.6rem;
    font-weight: 400;
    letter-spacing: 0.18em;
    color: var(--text-dim);
  }
  .site-footer {
    border-top: 1px solid var(--line);
    color: var(--text-dim);
    font-size: 0.8rem;
    text-align: center;
    padding: 1rem;
  }
  h1 {
    font-size: 1.5rem;
    line-height: 1.4;
  }
  .lead {
    color: var(--text-dim);
  }
  .card-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    padding: 0;
    list-style: none;
  }
  @media (prefers-reduced-motion: reduce) {
    *,
    *::before,
    *::after {
      transition-duration: 0.01ms !important;
      animation-duration: 0.01ms !important;
    }
  }
</style>
