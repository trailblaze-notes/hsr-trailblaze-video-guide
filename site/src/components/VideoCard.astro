---
import { VIDEO_TYPE_LABELS, type Video } from '../lib/schema';

interface Props {
  video: Video;
}
const { video } = Astro.props;
const watchUrl = `https://www.youtube.com/watch?v=${video.youtubeId}`;
// プライバシー強化モードの公式埋め込みプレイヤー。サムネ・再生とも YouTube 側で完結する
const embedUrl = `https://www.youtube-nocookie.com/embed/${video.youtubeId}`;
---
<article class="video-card">
  {video.embeddable && (
    <div class="embed">
      <iframe
        src={embedUrl}
        title={video.title}
        loading="lazy"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
        allowfullscreen></iframe>
    </div>
  )}
  <div class="body">
    <p class="meta">
      <span class="badge">{VIDEO_TYPE_LABELS[video.type]}</span>
      <span class="date">{video.publishedAt}</span>
    </p>
    <h3><a href={watchUrl} target="_blank" rel="noopener noreferrer">{video.title}</a></h3>
    <p class="watch"><a href={watchUrl} target="_blank" rel="noopener noreferrer">YouTube で見る ↗</a></p>
  </div>
</article>

<style>
  .video-card {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    overflow: hidden;
    transition: border-color 0.15s;
  }
  .video-card:hover {
    border-color: var(--accent);
  }
  .embed {
    aspect-ratio: 16 / 9;
    background: #000;
  }
  .embed iframe {
    width: 100%;
    height: 100%;
    border: 0;
    display: block;
  }
  .body {
    padding: 0.8rem 1rem 0.9rem;
  }
  .meta {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin: 0;
  }
  .badge {
    display: inline-block;
    background: var(--accent-soft);
    color: var(--accent);
    border-radius: 4px;
    font-size: 0.72rem;
    font-weight: 700;
    padding: 0.12rem 0.5rem;
  }
  .date {
    color: var(--text-dim);
    font-family: var(--mono);
    font-size: 0.74rem;
  }
  h3 {
    margin: 0.45rem 0 0.3rem;
    font-size: 0.98rem;
    line-height: 1.5;
  }
  h3 a {
    color: var(--text);
    text-decoration: none;
  }
  h3 a:hover {
    color: var(--accent);
  }
  .watch {
    margin: 0.55rem 0 0;
    font-size: 0.8rem;
  }
  .watch a {
    text-decoration: none;
  }
  .watch a:hover {
    text-decoration: underline;
  }
</style>
