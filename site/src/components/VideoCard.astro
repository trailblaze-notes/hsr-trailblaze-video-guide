---
import type { Video } from '../lib/schema';

interface Props {
  video: Video;
  rank: number;
  hidden: boolean;
}
const { video, rank, hidden } = Astro.props;
const watchUrl = `https://www.youtube.com/watch?v=${video.youtubeId}`;
const thumbUrl = `https://i.ytimg.com/vi/${video.youtubeId}/hqdefault.jpg`;
---
<article class="video-card" data-rank={rank} hidden={hidden}>
  <a class="thumb" href={watchUrl} target="_blank" rel="noopener noreferrer">
    <img src={thumbUrl} alt="" loading="lazy" onerror="this.closest('.thumb').classList.add('noimg'); this.remove()" />
    <span class="play">▶</span>
  </a>
  <div class="body">
    <span class="badge">{video.type}</span>
    <h3>
      <a href={watchUrl} target="_blank" rel="noopener noreferrer">{video.title}</a>
    </h3>
    <p class="reason">{video.reason}</p>
  </div>
</article>

<style>
  .video-card {
    display: flex;
    gap: 1rem;
    background: var(--surface);
    border: 1px solid var(--surface-2);
    border-radius: var(--radius);
    padding: 0.9rem;
  }
  .video-card[hidden] {
    display: none;
  }
  .thumb {
    position: relative;
    flex: 0 0 160px;
    aspect-ratio: 16 / 9;
    border-radius: 8px;
    overflow: hidden;
    background: linear-gradient(135deg, var(--surface-2), #2e3450);
    align-self: flex-start;
  }
  .thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .play {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    color: #fff;
    font-size: 1.4rem;
    text-shadow: 0 1px 6px rgba(0, 0, 0, 0.7);
    opacity: 0.85;
  }
  .body {
    min-width: 0;
  }
  .badge {
    display: inline-block;
    background: var(--surface-2);
    color: var(--accent);
    border-radius: 999px;
    font-size: 0.72rem;
    padding: 0.1rem 0.6rem;
  }
  h3 {
    margin: 0.35rem 0;
    font-size: 1rem;
  }
  h3 a {
    color: var(--text);
    text-decoration: none;
  }
  h3 a:hover {
    color: var(--accent);
  }
  .reason {
    margin: 0;
    color: var(--text-dim);
    font-size: 0.85rem;
  }
  @media (max-width: 560px) {
    .video-card {
      flex-direction: column;
    }
    .thumb {
      flex-basis: auto;
      width: 100%;
    }
  }
</style>
