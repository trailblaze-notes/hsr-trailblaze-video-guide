---
import Base from '../../layouts/Base.astro';
import MajorCard from '../MajorCard.astro';
import { loadVersions, groupByMajor, type VideoType } from '../../lib/schema';
import { STRINGS, langBase, type Lang } from '../../lib/i18n';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = STRINGS[lang];
const versions = loadVersions(lang);
const groups = groupByMajor(versions, lang);
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const root = langBase(base, lang);

const countOf = (type: VideoType) =>
  versions.reduce((sum, v) => sum + v.videos.filter((video) => video.type === type).length, 0);
const countText = (n: number) => (lang === 'ja' ? `${n} 件` : `${n} videos`);
---
<Base title={t.siteTitle} lang={lang}>
  <h1>{t.homeH1}</h1>
  <p class="lead">
    {t.homeLead1}<strong>{t.homeLeadBefore}</strong>{t.homeLeadAnd}<strong>{t.homeLeadAfter}</strong>{t.homeLead2}
  </p>

  <ul class="card-grid">
    {groups.map((group) => <MajorCard group={group} lang={lang} />)}
  </ul>

  <section class="type-links">
    <h2>{t.typeLinksHeading}</h2>
    <div class="type-grid">
      <a class="type-link" href={`${root}type/character/`}>
        <span class="t-label">{lang === 'ja' ? 'キャラクターPV' : 'Character Trailers'}</span>
        <span class="t-meta">{countText(countOf('character'))} ・ {t.typeCharacterDesc}</span>
      </a>
      <a class="type-link" href={`${root}type/trailblaze/`}>
        <span class="t-label">{lang === 'ja' ? '紀行PV・ストーリー' : 'Story & Myriad Celestia Trailers'}</span>
        <span class="t-meta">{countText(countOf('trailblaze'))} ・ {t.typeTrailblazeDesc}</span>
      </a>
      <a class="type-link" href={`${root}type/music/`}>
        <span class="t-label">{lang === 'ja' ? '曲（EP・MV・アニメーション）' : 'Music (EP / MV / Animation)'}</span>
        <span class="t-meta">{countText(countOf('music'))} ・ {t.typeMusicDesc}</span>
      </a>
    </div>
  </section>
</Base>

<style>
  .type-links h2 {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    font-size: 1.1rem;
    margin: 2rem 0 0.8rem;
    padding-bottom: 0.4rem;
    border-bottom: 1px solid var(--line);
  }
  .type-links h2::before {
    content: '';
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 0 3px var(--accent-soft);
  }
  .type-grid {
    display: grid;
    gap: 0.9rem;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
  }
  .type-link {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 1rem 1.2rem;
    color: var(--text);
    text-decoration: none;
    transition: border-color 0.15s, background 0.15s;
  }
  .type-link:hover {
    border-color: var(--accent);
    background: var(--surface-2);
  }
  .t-label {
    font-weight: 700;
    font-size: 1.02rem;
  }
  .t-meta {
    color: var(--text-dim);
    font-family: var(--mono);
    font-size: 0.76rem;
  }
</style>
