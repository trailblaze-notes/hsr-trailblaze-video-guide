---
import type { MajorGroup } from '../lib/schema';

interface Props {
  prev: MajorGroup | null;
  next: MajorGroup | null;
}
const { prev, next } = Astro.props;
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
---
<nav class="version-nav">
  {prev ? <a href={`${base}v/${prev.major}/`}>← Ver.{prev.major}.x</a> : <span></span>}
  <a class="index-link" href={base}>一覧</a>
  {next ? <a href={`${base}v/${next.major}/`}>Ver.{next.major}.x →</a> : <span></span>}
</nav>

<style>
  .version-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.5rem;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 0.5rem 0.9rem;
    margin: 0.8rem 0;
    font-size: 0.88rem;
  }
  .version-nav a {
    text-decoration: none;
  }
  .version-nav a:hover {
    text-decoration: underline;
  }
  .index-link {
    color: var(--text-dim);
  }
</style>
